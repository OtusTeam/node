{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": [
      "@swc/jest",
      {
        "jsc": {
          "parser": {
            "syntax": "typescript",
            "decorators": true,
            "dynamicImport": true
          },
          "transform": {
            "legacyDecorator": true,
            "decoratorMetadata": true
          },
          "target": "es2021",
          "keepClassNames": true
        },
        "module": {
          "type": "commonjs"
        },
        "sourceMaps": true
      }
    ]
  },
  "testTimeout": 30000,
  "maxWorkers": 1,
  "verbose": true
}
